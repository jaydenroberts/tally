#!/usr/bin/env bash
# pre-push — CITADEL client-side personal-data / secret gate (Tally canonical dev box).
#
# Fast, fail-closed pre-push scan run on the operator's box before commits leave
# for GitHub. This is the FIRST line; the AUTHORITATIVE gate is the GitHub Actions
# backstop job (server-side, unbypassable). This hook is intentionally bypassable
# (`--no-verify`, or a tampered PATTERN_DIR) — the CI backstop catches anything a
# bypassed client misses.
#
# Install (versioned, recommended — survives reclone with the repo):
#   mkdir -p .githooks
#   cp ci/pre-push .githooks/pre-push        # or symlink to the vault copy
#   chmod +x .githooks/pre-push
#   git config core.hooksPath .githooks      # per-clone; set once after cloning
#
# (Alternative: cp to .git/hooks/pre-push — not versioned, lost on reclone.)
#
# git feeds stdin one line per ref being pushed:
#   <local_ref> <local_oid> <remote_ref> <remote_oid>
#
# Exit: 0 = allow push;  non-zero = abort push (fail-closed).

set -uo pipefail

VAULT_DIR="${VAULT_DIR:-/home/ai-ops/vault}"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
# Prefer the repo-vendored scanner: it carries the --ci mode, travels with the repo,
# and is the SAME file the GitHub Actions backstop runs — client + CI stay in lockstep.
# Fall back to the vault canonical only if the repo copy is absent. SCANNER env still overrides.
if [[ -x "${REPO_ROOT}/ci/scanner.sh" ]]; then
    SCANNER="${SCANNER:-${REPO_ROOT}/ci/scanner.sh}"
else
    SCANNER="${SCANNER:-${VAULT_DIR}/ci/scanner.sh}"
fi
ZERO="0000000000000000000000000000000000000000"

if [[ ! -x "${SCANNER}" ]]; then
    echo "[pre-push] ERROR: scanner not found/executable at ${SCANNER} — failing closed." >&2
    exit 2
fi

# Scan a commit RANGE via the scanner's reliable UPDATE path (old..new).
# --ci => quiet pattern literals + log-dir non-fatal (client-safe). Returns the
# scanner's exit code (0 clean / 1 finding / 2 error).
_scan_range() {
    local oldrev="$1" newrev="$2" ref="$3"
    printf '%s %s %s\n' "${oldrev}" "${newrev}" "${ref}" | "${SCANNER}" --ci --prereceive
}

rc=0
while read -r local_ref local_oid remote_ref remote_oid; do
    [[ -z "${local_ref:-}" ]] && continue

    # Branch DELETE (local_oid all zeros): nothing to scan.
    if [[ "${local_oid}" == "${ZERO}" ]]; then
        continue
    fi

    if [[ "${remote_oid}" != "${ZERO}" ]]; then
        # UPDATE: scan exactly the delta the remote does not yet have.
        _scan_range "${remote_oid}" "${local_oid}" "${remote_ref}"; src=$?
        [[ ${src} -ne 0 ]] && rc=${src}
        continue
    fi

    # ---- NEW BRANCH (remote has no such ref) -------------------------------
    # The naive `git rev-list <new> --not --branches` is FAIL-OPEN client-side:
    # the pushed branch is already a local branch, so it returns empty and the
    # commits go UNSCANNED. Use the remote-tracking boundary instead so we scan
    # exactly the commits not already on any remote.
    new_count=$(git rev-list --count "${local_oid}" --not --remotes 2>/dev/null || echo "?")
    if [[ "${new_count}" == "0" ]]; then
        continue   # every commit already exists on some remote — nothing new
    fi
    # Boundary base = the youngest commit already on a remote that is an ancestor
    # of what we're pushing. `base..local` reproduces `rev-list local --not
    # --remotes` (one base captures all new commits; any over-scan of already
    # pushed commits is harmless). Routes through the scanner's UPDATE path, so
    # it never touches the client-broken new-ref enumeration.
    base=$(git rev-list --boundary "${local_oid}" --not --remotes 2>/dev/null | sed -n 's/^-//p' | head -n1)
    if [[ -n "${base}" ]]; then
        _scan_range "${base}" "${local_oid}" "${remote_ref}"; src=$?
        [[ ${src} -ne 0 ]] && rc=${src}
    else
        # No remote-tracking ancestor (brand-new / disjoint history). We cannot
        # compute a safe delta base -> FAIL CLOSED rather than risk an unscanned
        # push. (For the canonical Tally box this never happens: the GitHub repo
        # is already cloned, so remote-tracking refs exist.)
        echo "[pre-push] No remote-tracking ancestor for ${remote_ref} (disjoint/new history)." >&2
        echo "[pre-push] Refusing to push unscanned history (fail-closed)." >&2
        echo "[pre-push] Scan the full history first: ${VAULT_DIR}/ci/full-history-scan.sh" >&2
        rc=2
    fi
done

if [[ ${rc} -ne 0 ]]; then
    echo "" >&2
    echo "[pre-push] CITADEL gate: PUSH ABORTED (rc=${rc})." >&2
    echo "[pre-push] For finding detail, re-scan locally: ${SCANNER} --file <path>" >&2
    exit "${rc}"
fi
exit 0
