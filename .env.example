# Copy this to .env and fill in values before running

# Required: long random string for JWT signing
SECRET_KEY=replace-me-with-a-long-random-string

# Optional: token lifetime (days, default 30)
ACCESS_TOKEN_EXPIRE_DAYS=30

# Optional: auto-create first owner on first run
# FIRST_RUN_OWNER_USERNAME=yourname
# FIRST_RUN_OWNER_PASSWORD=yourpassword

# ---------------------------------------------------------------------------
# AI Chat (Phase 4) — all optional; chat endpoint is disabled if AI_API_KEY
# is not set and the default Anthropic provider is used.
# ---------------------------------------------------------------------------

# Provider: "anthropic" (default) or "openai"
# Use "openai" for OpenAI, Ollama, LM Studio, or any OpenAI-compatible endpoint.
AI_PROVIDER=anthropic

# API key for the selected provider.
# Anthropic: get one at https://console.anthropic.com
# OpenAI:    get one at https://platform.openai.com/api-keys
# Ollama:    leave blank or set to any non-empty string (e.g. "ollama")
AI_API_KEY=

# Model identifier.
# Anthropic default: claude-sonnet-4-6
# OpenAI default:    gpt-4o
# Ollama example:    llama3.2
AI_MODEL=

# Base URL override — required for Ollama and other local/compatible endpoints.
# Ollama default: http://localhost:11434/v1
# Leave blank when using Anthropic or OpenAI directly.
AI_BASE_URL=
