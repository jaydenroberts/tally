# Copy this to .env and fill in values before running

# Required: long random string for JWT signing
SECRET_KEY=replace-me-with-a-long-random-string

# Optional: token lifetime (days, default 30)
ACCESS_TOKEN_EXPIRE_DAYS=30

# Optional: auto-create first owner on first run
# FIRST_RUN_OWNER_USERNAME=yourname
# FIRST_RUN_OWNER_PASSWORD=yourpassword
